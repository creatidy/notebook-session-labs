{
  "mcpServers": {
    "notebook-session-labs": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e", "NSL_BRIDGE_HOST=host.docker.internal",
        "-e", "NSL_BRIDGE_PORT=3939",
        "ghcr.io/creatidy/notebook-session-labs-mcp:latest"
      ],
      "disabled": false
    }
  }
}