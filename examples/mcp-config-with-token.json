{
  "_comment": "Advanced config with token auth enabled. Use this when notebookSessionLabs.bridge.authMode is set to 'token' in VS Code settings.",
  "mcpServers": {
    "notebook-session-labs": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "NSL_BRIDGE_HOST=host.docker.internal",
        "-e", "NSL_BRIDGE_PORT=3939",
        "-e", "NSL_BRIDGE_TOKEN=your-token-here",
        "ghcr.io/creatidy/notebook-session-labs-mcp:latest"
      ],
      "disabled": false
    }
  }
}