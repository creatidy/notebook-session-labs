{
  "_comment": "Advanced config with token auth enabled. Use this when notebookSessionLabs.bridge.authMode is set to 'token' in VS Code settings. The port is auto-discovered via the port file volume mount.",
  "mcpServers": {
    "notebook-session-labs": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-v",
        "/tmp/notebook-session-labs:/tmp/notebook-session-labs",
        "-e",
        "NSL_BRIDGE_HOST=host.docker.internal",
        "-e",
        "NSL_BRIDGE_TOKEN=your-token-here",
        "ghcr.io/creatidy/notebook-session-labs-mcp:latest"
      ],
      "disabled": false
    }
  }
}