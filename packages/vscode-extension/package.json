{
  "name": "notebook-session-labs",
  "displayName": "Notebook Session Labs",
  "description": "A local bridge for live notebook sessions inside VS Code",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "publisher": "creatidy",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Notebooks", "Programming Languages", "Other"],
  "keywords": ["notebook", "mcp", "bridge", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/creatidy/notebook-session-labs.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/creatidy/notebook-session-labs#readme",
  "bugs": {
    "url": "https://github.com/creatidy/notebook-session-labs/issues"
  },
  "activationEvents": [
    "onNotebook:*",
    "onCommand:notebookSessionLabs.startBridge",
    "onCommand:notebookSessionLabs.stopBridge"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "notebookSessionLabs.startBridge",
        "title": "Notebook Session Labs: Start Bridge"
      },
      {
        "command": "notebookSessionLabs.stopBridge",
        "title": "Notebook Session Labs: Stop Bridge"
      },
      {
        "command": "notebookSessionLabs.showBridgeStatus",
        "title": "Notebook Session Labs: Show Bridge Status"
      }
    ],
    "configuration": {
      "title": "Notebook Session Labs",
      "properties": {
        "notebookSessionLabs.bridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the local notebook bridge server"
        },
        "notebookSessionLabs.bridge.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host address for the bridge server (loopback only recommended)"
        },
        "notebookSessionLabs.bridge.port": {
          "type": "number",
          "default": 0,
          "description": "Port for the bridge server (0 = ephemeral)"
        },
        "notebookSessionLabs.bridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the bridge when a notebook is opened"
        },
        "notebookSessionLabs.bridge.authMode": {
          "type": "string",
          "default": "none",
          "enum": ["none", "token"],
          "enumDescriptions": [
            "No token required for local loopback connections (default)",
            "Require an ephemeral bearer token for all bridge requests"
          ],
          "description": "Bridge authentication mode. 'none' for local loopback (default), 'token' for optional hardening"
        },
        "notebookSessionLabs.logging.level": {
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Log level for the extension"
        },
        "notebookSessionLabs.output.maxSize": {
          "type": "number",
          "default": 100000,
          "description": "Maximum output size in bytes per cell"
        },
        "notebookSessionLabs.output.includeImages": {
          "type": "boolean",
          "default": true,
          "description": "Include image outputs in cell output data"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "vscode:prepublish": "pnpm build && rm -f dist/*.map",
    "package": "vsce package --no-dependencies",
    "publish:ext": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@notebook-session-labs/shared": "workspace:*",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^22.14.0",
    "@vscode/vsce": "^3.3.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}