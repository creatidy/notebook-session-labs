{
  "name": "@notebook-session-labs/mcp-server",
  "version": "0.4.0",
  "description": "MCP server for Notebook Session Labs - bridges to VS Code notebook sessions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "notebook-session-labs-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@notebook-session-labs/shared": "workspace:*",
    "pino": "^9.6.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
